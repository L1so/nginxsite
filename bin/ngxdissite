#!/bin/bash

# Disabling site in NginX
# Credit to: https://gist.github.com/fideloper/8261546
nginx_available="/etc/nginx/sites-available"
nginx_enabled="/etc/nginx/sites-enabled"

if [[ $EUID -ne 0 ]]; then
   echo "This script must be run as root"
   exit 1
fi

# -z str: Returns True if the length of str is equal to zero.
if [ $# -eq 0 ]; then
  title="Please select a website"
  while IFS= read -r; do sitelist+=("$REPLY"); done < <(find $nginx_enabled -type l -print0 | xargs --null basename -a 2> /dev/null)
  if [ ${#sitelist[@]} -eq 0 ]; then
    echo "No site is being enabled !"
    exit 0
  else
    COLUMNS=1
    echo "$title"
    PS3="Pick an option: "
    select opt in "${sitelist[@]}" "Cancel"; do
      if [ "$opt" = "Cancel" ]; then
        echo 'Bye!' >&2
        exit
      elif [ -z "$opt" ]; then
        echo "Invalid choices" >&2
      else
        [ -L "${nginx_enabled}/$opt" ] && rm "${nginx_enabled}/$opt"
        echo "Successfully disabling $opt !"
        break
      fi
    done
  fi
else
    # -h filename: True if file exists and is a symbolic link.
    # -f filename: Returns True if file, filename is an ordinary file.
    optsite="$1"
    set -- "$(basename $optsite)"
    if [ -L "${nginx_enabled}/$optsite" ]; then
      if [ -e "${nginx_enabled}/$optsite" ]; then
        rm "${nginx_enabled}/$optsite"
        echo "Successfully disabling $optsite !"
      else
        echo "$optsite is a broken symlink, check $nginx_available for $optsite existence !"
        exit 1
      fi
    elif [ -e "${nginx_enabled}/$optsite" ]; then
      echo "$optsite is not valid file"
      exit 1
    else
      echo "$optsite does not exist !"
      exit 1
    fi
fi
